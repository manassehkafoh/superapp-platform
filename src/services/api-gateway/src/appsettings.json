{
  "Auth": {
    "Authority": "https://login.microsoftonline.com/__tenant_id__/v2.0",
    "Audience":  "api://superapp-api-gateway"
  },
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "default",
        "Match": { "Path": "/api/v1/auth/{**catch-all}" }
      },
      "payment-route": {
        "ClusterId": "payment-cluster",
        "AuthorizationPolicy": "default",
        "Match": { "Path": "/api/v1/payments/{**catch-all}" }
      },
      "wallet-route": {
        "ClusterId": "wallet-cluster",
        "AuthorizationPolicy": "default",
        "Match": { "Path": "/api/v1/wallets/{**catch-all}" }
      },
      "account-route": {
        "ClusterId": "account-cluster",
        "AuthorizationPolicy": "default",
        "Match": { "Path": "/api/v1/accounts/{**catch-all}" }
      }
    },
    "Clusters": {
      "identity-cluster":  { "Destinations": { "d1": { "Address": "http://identity-api.superapp-services.svc.cluster.local:8080" } } },
      "payment-cluster":   { "Destinations": { "d1": { "Address": "http://payment-api.superapp-services.svc.cluster.local:8080" } } },
      "wallet-cluster":    { "Destinations": { "d1": { "Address": "http://wallet-api.superapp-services.svc.cluster.local:8080" } } },
      "account-cluster":   { "Destinations": { "d1": { "Address": "http://account-api.superapp-services.svc.cluster.local:8080" } } }
    }
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "GeneralRules": [
      { "Endpoint": "POST:/api/v1/payments/*", "Period": "1m", "Limit": 10 },
      { "Endpoint": "POST:/api/v1/auth/login", "Period": "5m", "Limit": 5 },
      { "Endpoint": "*",                       "Period": "1s", "Limit": 50 }
    ]
  }
}
