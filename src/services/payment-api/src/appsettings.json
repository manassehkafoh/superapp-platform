{
  "Logging": {
    "LogLevel": { "Default": "Information", "Microsoft.AspNetCore": "Warning" }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "PaymentDb": "__injected_by_external_secrets__",
    "Redis":     "__injected_by_external_secrets__"
  },
  "Messaging": {
    "BootstrapServers": "__injected_by_external_secrets__",
    "SchemaRegistryUrl": "__injected_by_external_secrets__"
  },
  "Auth": {
    "Authority": "https://login.microsoftonline.com/__tenant_id__/v2.0",
    "Audience":  "api://superapp-payment-api"
  },
  "PaymentRails": {
    "GhIPSS": {
      "BaseUrl": "https://api.ghipss.com.gh",
      "TimeoutSeconds": 30
    },
    "ExpressPay": {
      "BaseUrl": "https://expresspaygh.com/api",
      "TimeoutSeconds": 30
    }
  },
  "Resilience": {
    "RetryCount":       3,
    "CircuitBreakerThreshold": 5,
    "TimeoutSeconds":   10
  },
  "Telemetry": {
    "OtlpEndpoint": "http://opentelemetry-collector.monitoring.svc.cluster.local:4317",
    "ServiceName":  "payment-api",
    "ServiceVersion": "1.0.0"
  },
  "Limits": {
    "BasicTierDailyLimitGHS":   500,
    "PremiumTierDailyLimitGHS": 5000,
    "BusinessTierDailyLimitGHS": 50000
  }
}
