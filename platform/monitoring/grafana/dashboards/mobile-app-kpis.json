{
  "__inputs": [
    { "name": "DS_PROMETHEUS",     "label": "Prometheus",     "type": "datasource", "pluginId": "prometheus" },
    { "name": "DS_ELASTICSEARCH",  "label": "Elasticsearch",  "type": "datasource", "pluginId": "elasticsearch" },
    { "name": "DS_LOKI",           "label": "Loki",           "type": "datasource", "pluginId": "loki" }
  ],
  "title": "SuperApp Mobile — Republic Bank Ghana KPI Dashboard",
  "description": "KPIs aligned to Republic Bank Ghana Channel Performance Framework. Digital Channel (Mobile & Internet Banking) section.",
  "uid": "superapp-mobile-kpis",
  "version": 1,
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "timezone": "Africa/Accra",
  "tags": ["superapp", "mobile", "kpi", "republic-bank"],
  "fiscalYearStartMonth": 0,

  "templating": {
    "list": [
      {
        "name": "interval",
        "type": "interval",
        "label": "Interval",
        "current": { "text": "5m", "value": "5m" },
        "options": [
          { "text": "1m",  "value": "1m" },
          { "text": "5m",  "value": "5m" },
          { "text": "15m", "value": "15m" },
          { "text": "1h",  "value": "1h" },
          { "text": "6h",  "value": "6h" },
          { "text": "1d",  "value": "1d" }
        ],
        "hide": 0
      },
      {
        "name": "environment",
        "type": "custom",
        "label": "Environment",
        "current": { "text": "prod", "value": "prod" },
        "options": [
          { "text": "prod",    "value": "prod" },
          { "text": "staging", "value": "staging" },
          { "text": "dev",     "value": "dev" }
        ],
        "hide": 0
      }
    ]
  },

  "panels": [

    {
      "id": 1,
      "type": "row",
      "title": "📱 KPI Summary — Digital Channel (Mobile & Internet Banking)",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },

    {
      "id": 2,
      "title": "KPI-1 Active Users Ratio",
      "description": "Active users ÷ Total registered users (%)\nTarget: ≥ 60%",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 6 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 40 },
              { "color": "green",  "value": 60 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "superapp:mobile_active_users_ratio",
          "legendFormat": "Active Users Ratio %"
        }
      ]
    },

    {
      "id": 3,
      "title": "KPI-2 Adoption Rate",
      "description": "New digital enrollments ÷ Total customers (%)\nTarget: ≥ 5% monthly",
      "type": "gauge",
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 6 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 20,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "green",  "value": 5 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "superapp:mobile_adoption_rate",
          "legendFormat": "Adoption Rate %"
        }
      ]
    },

    {
      "id": 4,
      "title": "KPI-5 System Availability",
      "description": "% of time service is fully available\nTarget: ≥ 99.9%",
      "type": "gauge",
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 6 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 95,
          "max": 100,
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 99 },
              { "color": "green",  "value": 99.9 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "avg(superapp:mobile_system_availability_percent)",
          "legendFormat": "Availability %"
        }
      ]
    },

    {
      "id": 5,
      "title": "KPI-6 Failed Transaction Rate",
      "description": "Failed transactions ÷ Total transactions (%)\nTarget: < 0.1%",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 1, "w": 4, "h": 6 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 5,
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red",    "value": 0.5 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "superapp:mobile_failed_transaction_rate",
          "legendFormat": "Failed Rate %"
        }
      ]
    },

    {
      "id": 6,
      "title": "KPI-8 NPS Score",
      "description": "Net Promoter Score (survey-based)\nTarget: ≥ 40",
      "type": "gauge",
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 6 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": -100,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 0 },
              { "color": "green",  "value": 40 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "superapp:mobile_nps_score",
          "legendFormat": "NPS"
        }
      ]
    },

    {
      "id": 7,
      "title": "SLO Error Budget Remaining",
      "description": "% of monthly error budget remaining (99.9% SLO)\nTarget: > 0%",
      "type": "gauge",
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 6 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 25 },
              { "color": "green",  "value": 50 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "clamp_min(superapp:payment_error_budget_remaining * 100, 0)",
          "legendFormat": "Error Budget %"
        }
      ]
    },

    {
      "id": 10,
      "type": "row",
      "title": "📊 KPI-3 & KPI-4 — Transaction Volume & Value",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 7, "w": 24, "h": 1 }
    },

    {
      "id": 11,
      "title": "KPI-3 Transaction Volume (hourly)",
      "description": "Number of mobile transactions per hour",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 30,
            "lineWidth": 2,
            "spanNulls": false,
            "thresholdsStyle": { "mode": "dashed+area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10000 }
            ]
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "showLegend": true, "displayMode": "table", "placement": "bottom", "calcs": ["last", "max", "sum"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "superapp:mobile_transaction_volume_hourly",
          "legendFormat": "Transactions/hour"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "superapp:mobile_transaction_volume_hourly{status=\"completed\"}",
          "legendFormat": "Successful"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "superapp:mobile_transaction_volume_hourly{status=\"failed\"}",
          "legendFormat": "Failed"
        }
      ]
    },

    {
      "id": 12,
      "title": "KPI-4 Transaction Value GHS (daily)",
      "description": "Total value of mobile transactions processed (GHS)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyGHS",
          "color": { "mode": "fixed", "fixedColor": "green" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "gradientMode": "scheme"
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "showLegend": true, "displayMode": "table", "placement": "bottom", "calcs": ["last", "max", "sum"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "superapp:mobile_transaction_value_ghs_daily",
          "legendFormat": "Daily Value (GHS)"
        }
      ]
    },

    {
      "id": 20,
      "type": "row",
      "title": "⚡ Service Performance — API Latency & Availability",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 1 }
    },

    {
      "id": 21,
      "title": "API Response Time — p50 / p95 / p99",
      "description": "HTTP response time percentiles across all mobile-facing services",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 17, "w": 16, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 5
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red",    "value": 2000 }
            ]
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "p99" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "p95" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "p50" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "showLegend": true, "displayMode": "table", "placement": "right", "calcs": ["last", "max", "mean"] }
      },
      "targets": [
        { "datasource": { "type": "prometheus" }, "expr": "superapp:api_latency_p50_ms", "legendFormat": "p50" },
        { "datasource": { "type": "prometheus" }, "expr": "superapp:api_latency_p95_ms", "legendFormat": "p95" },
        { "datasource": { "type": "prometheus" }, "expr": "superapp:api_latency_p99_ms", "legendFormat": "p99" }
      ]
    },

    {
      "id": 22,
      "title": "Service Availability (24h)",
      "description": "Per-service availability % over rolling 24h window",
      "type": "bargauge",
      "gridPos": { "x": 16, "y": 17, "w": 8, "h": 8 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 98,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 99 },
              { "color": "green",  "value": 99.9 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "superapp:service_availability_percent",
          "legendFormat": "{{job}}"
        }
      ]
    },

    {
      "id": 30,
      "type": "row",
      "title": "👥 KPI-7 Login Frequency & User Engagement",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 25, "w": 24, "h": 1 }
    },

    {
      "id": 31,
      "title": "KPI-7 Average Login Frequency (30-day rolling)",
      "description": "Logins per active customer per month\nTarget: ≥ 8 logins/month",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 26, "w": 8, "h": 7 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "green",  "value": 8 }
            ]
          }
        }
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "showLegend": true }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "superapp:mobile_avg_login_frequency",
          "legendFormat": "Avg Logins/Customer/Month"
        }
      ]
    },

    {
      "id": 32,
      "title": "Active Sessions (real-time)",
      "description": "Current concurrent active user sessions",
      "type": "stat",
      "gridPos": { "x": 8, "y": 26, "w": 4, "h": 7 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue",  "value": null },
              { "color": "green", "value": 1000 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "superapp:active_sessions_total",
          "legendFormat": "Active Sessions"
        }
      ]
    },

    {
      "id": 33,
      "title": "User Registration Trend",
      "description": "New user registrations (KPI-2 Adoption Rate driver)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 26, "w": 12, "h": 7 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 40,
            "lineWidth": 1
          }
        }
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "showLegend": true }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "increase(superapp_user_registrations_total[$__interval])",
          "legendFormat": "New Registrations"
        }
      ]
    },

    {
      "id": 40,
      "type": "row",
      "title": "💳 Payment Processing Detail",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 33, "w": 24, "h": 1 }
    },

    {
      "id": 41,
      "title": "Payment Success vs Failed Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 34, "w": 12, "h": 7 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Failed Rate %" }, "properties": [{ "id": "color", "value": { "fixedColor": "red",   "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Success Rate %" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "showLegend": true, "displayMode": "table", "placement": "bottom", "calcs": ["last", "mean"] }
      },
      "targets": [
        { "datasource": { "type": "prometheus" }, "expr": "superapp:payment_success_rate_percent", "legendFormat": "Success Rate %" },
        { "datasource": { "type": "prometheus" }, "expr": "superapp:mobile_failed_transaction_rate", "legendFormat": "Failed Rate %" }
      ]
    },

    {
      "id": 42,
      "title": "Payment Rail Breakdown",
      "description": "Transaction volume by payment rail (GhIPSS, ExpressPay, InternalTransfer)",
      "type": "piechart",
      "gridPos": { "x": 12, "y": 34, "w": 6, "h": 7 },
      "options": {
        "pieType": "donut",
        "displayLabels": ["name", "percent"],
        "legend": { "showLegend": true, "displayMode": "table", "placement": "right" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum by (rail) (increase(superapp_payment_transactions_total[$__range]))",
          "legendFormat": "{{rail}}"
        }
      ]
    },

    {
      "id": 43,
      "title": "SLO Burn Rate",
      "description": "Error budget consumption rate\n1h burn: critical if > 14.4×\n6h burn: warning if > 6×",
      "type": "timeseries",
      "gridPos": { "x": 18, "y": 34, "w": 6, "h": 7 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.006 },
              { "color": "red",    "value": 0.0144 }
            ]
          }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus" }, "expr": "superapp:payment_slo_burn_rate_1h", "legendFormat": "1h burn rate" },
        { "datasource": { "type": "prometheus" }, "expr": "superapp:payment_slo_burn_rate_6h", "legendFormat": "6h burn rate" }
      ]
    },

    {
      "id": 50,
      "type": "row",
      "title": "📋 Log Analytics — ELK / Transaction Events",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 41, "w": 24, "h": 1 }
    },

    {
      "id": 51,
      "title": "Transaction Events (Elasticsearch)",
      "description": "Live transaction event stream from Elasticsearch KPI index",
      "type": "logs",
      "gridPos": { "x": 0, "y": 42, "w": 24, "h": 8 },
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": { "type": "loki" },
          "expr": "{app=~\"payment-api|wallet-api\"} |= \"payment\" | json | line_format \"[{{.level}}] {{.service}} | txn={{.paymentId}} amount={{.amount}} status={{.status}} user={{.userId}}\"",
          "legendFormat": ""
        }
      ]
    },

    {
      "id": 52,
      "title": "Error Log Frequency by Service (ELK)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 50, "w": 12, "h": 7 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "fillOpacity": 60 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "showLegend": true, "displayMode": "table", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "loki" },
          "expr": "sum by (app) (count_over_time({namespace=\"superapp-services\"} |= \"ERROR\" [$__interval]))",
          "legendFormat": "{{app}} errors"
        }
      ]
    },

    {
      "id": 53,
      "title": "Kafka Consumer Lag by Topic",
      "description": "Real-time Kafka consumer lag — high lag = payment processing delays",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 50, "w": 12, "h": 7 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red",    "value": 10000 }
            ]
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "showLegend": true, "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "superapp:kafka_consumer_lag_total",
          "legendFormat": "{{topic}} / {{consumer_group}}"
        }
      ]
    },

    {
      "id": 60,
      "type": "row",
      "title": "🔄 Cross-Channel Metrics",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 57, "w": 24, "h": 1 }
    },

    {
      "id": 61,
      "title": "Channel Migration Rate (digital vs branch)",
      "description": "% of transactions moving from branch to digital\nTarget: > 70% digital",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 58, "w": 6, "h": 6 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green",  "value": 70 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "superapp:channel_migration_rate_percent",
          "legendFormat": "Digital %"
        }
      ]
    },

    {
      "id": 62,
      "title": "Total Wallet Balance (GHS)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 58, "w": 6, "h": 6 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyGHS",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "superapp:total_wallet_balance_ghs",
          "legendFormat": "Total Balance"
        }
      ]
    },

    {
      "id": 63,
      "title": "Payment Volume by Channel",
